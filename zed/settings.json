// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "cursor": {
      "favorite_config_option_values": {
        "model": [
          "composer-2[fast=true]"
        ]
      },
      "type": "registry",
    },
  },
  "notification_panel": {
    "button": false,
  },
  "toolbar": {
    "agent_review": false,
    "breadcrumbs": true,
    "code_actions": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "document_symbols": "on",
  "use_system_path_prompts": true,
  "agent": {
    "message_editor_min_lines": 6,
    "show_turn_stats": true,
    "default_profile": "ask",
    "cancel_generation_on_terminal_stop": true,
    "use_modifier_to_send": true,
    "button": false,
    "play_sound_when_agent_done": true,
    "enable_feedback": false,
    "expand_terminal_card": true,
    "notify_when_agent_waiting": "primary_screen",
    "single_file_review": true,
  },
  "always_treat_brackets_as_autoclosed": true,
  "audio": {
    "experimental.auto_speaker_volume": false,
  },
  "auto_signature_help": false,
  "autosave": "on_focus_change",
  "base_keymap": "VSCode",
  "buffer_font_family": "HackGen Console NF",
  "buffer_font_features": {
    "calt": false,
  },
  "buffer_font_size": 16.0,
  "calls": {
    "mute_on_join": true,
  },
  "collaboration_panel": {
    "button": false,
  },
  "colorize_brackets": true,
  "diagnostics": {
    "lsp_pull_diagnostics": {
      "enabled": true,
    },
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
    },
  },
  "disable_ai": false,
  "edit_predictions": {
    "ollama": {
      "model": "qwen3.5:2b",
      "prompt_format": "qwen",
    },
    "mode": "eager",
    "provider": "copilot",
  },
  "file_finder": {
    "include_ignored": "smart",
  },
  "file_scan_exclusions": [
    "**/.svn",
    "**/.hg",
    "**/.repo",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
  ],
  "file_types": {
    "Git Config": [
      "**/git/**/config*"
    ],
    "Shell Script": [
      ".envrc"
    ],
    "Dockerfile": [
      "Dockerfile.*"
    ]
  },
  "git": {
    "hunk_style": "unstaged_hollow",
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "git_panel": {
    "button": false,
    "collapse_untracked_diff": false,
    "dock": "left",
    "tree_view": false,
    "sort_by_path": true,
    "status_style": "label_color",
    "show_count_badge": true,
    "file_icons": true,
  },
  "hard_tabs": false,
  "helix_mode": false,
  "icon_theme": "Catppuccin Latte",
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "fixed",
    "active_line_width": 2,
    "line_width": 2,
  },
  "inlay_hints": {
    "show_background": false,
    "enabled": true,
  },
  "prettier": {
    "allowed": false,
  },
  "project_panel": {
    "git_status_indicator": true,
    "button": false,
    "hide_root": true,
    "bold_folder_labels": true,
    "default_width": 400.0,
    "diagnostic_badges": true,
  },
  "search": {
    "include_ignored": false,
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "show_edit_predictions": true,
  "show_signature_help_after_edits": true,
  "sticky_scroll": {
    "enabled": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tab_size": 2,
  "tabs": {
    "git_status": true,
  },
  "tasks": {
    "enabled": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "button": false,
    "dock": "bottom",
    "default_height": 1000.0,
    "copy_on_select": true,
    "minimum_contrast": 0,
  },
  "theme": "Catppuccin Latte Transparent",
  "ui_font_family": "HackGen Console NF",
  "agent_buffer_font_size": 18,
  "ui_font_size": 20,
  "vim": {
    "cursor_shape": {
      "insert": "bar",
      "normal": "block",
    },
    "toggle_relative_line_numbers": true,
    "use_smartcase_find": true,
    "use_system_clipboard": "on_yank",
  },
  "vim_mode": true,
  "which_key": {
    "enabled": true,
    "delay_ms": 500,
  },
  "languages": {
    "Markdown": {
      "language_servers": [
        "!codebook",
        "..."
      ],
    },
  },
}
