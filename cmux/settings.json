{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux-settings.schema.json",
  "schemaVersion": 1,
  "shortcuts": {
    "bindings": {
      "splitRight": [
        "ctrl+j",
        "shift+\\"
      ],
      "splitDown": [
        "ctrl+j",
        "-"
      ],
      "focusLeft": [
        "ctrl+j",
        "h"
      ],
      "focusDown": [
        "ctrl+j",
        "j"
      ],
      "focusUp": [
        "ctrl+j",
        "k"
      ],
      "focusRight": [
        "ctrl+j",
        "l"
      ],
      "newSurface": [
        "ctrl+j",
        "c"
      ],
      "prevSurface": [
        "ctrl+j",
        "tab"
      ],
      "reloadConfiguration": [
        "ctrl+j",
        "r"
      ],
      "toggleSplitZoom": [
        "ctrl+j",
        "z"
      ],
      "showNotifications": [
        "ctrl+j",
        "i"
      ],
      "toggleTerminalCopyMode": [
        "ctrl+j",
        "["
      ]
    },
    "showModifierHoldHints": true
  }
}
